<footer class="bg-gray-50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Logo + tagline -->
      <div class="flex items-center gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-7 w-7">
          <defs>
            <linearGradient id="footer-bg" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#6366f1"/>
              <stop offset="100%" stop-color="#4f46e5"/>
            </linearGradient>
          </defs>
          <rect width="32" height="32" rx="7" fill="url(#footer-bg)"/>
          <path d="M18.5 4L9 18h6l-1.5 10L23 14h-6z" fill="#fff" stroke="#fff" stroke-width="0.5" stroke-linejoin="round"/>
        </svg>
        <div>
          <span class="text-sm font-semibold text-gray-900">Flash MDM</span>
          <span class="text-sm text-gray-500 ml-2">Android Device Management</span>
        </div>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href="https://flash-mdm.netlify.app" class="hover:text-primary-600 transition-colors">Console</a>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200 text-center">
      <p class="text-xs text-gray-400">&copy; 2026 Flash MDM. All rights reserved.</p>
    </div>
  </div>
</footer>
