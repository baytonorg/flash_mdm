# =============================================================================
# Flash MDM — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control (it's in .gitignore).
# On Netlify, set these in Site Settings > Environment Variables.
# For VPS deployments, see the install script or README.
# =============================================================================

# --- Database (Netlify DB / Postgres) ----------------------------------------
# Automatically provided by Netlify DB. Only needed for local/VPS development.
# For VPS: postgresql://user:password@localhost:5432/flash_mdm?sslmode=disable
DATABASE_URL=postgresql://localhost:5432/flash_mdm

# --- Encryption --------------------------------------------------------------
# 32-byte hex key for AES-256-GCM encryption of secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# --- Public URL ---------------------------------------------------------------
# Required for VPS/reverse-proxy deployments. Used for origin checks, magic
# link URLs, and iframe parent URLs. Netlify sets this automatically.
# URL=https://mdm.example.com

# --- Node environment ---------------------------------------------------------
# Set to "production" for HTTPS deployments (enables Secure cookie flag).
# Set to "development" for local HTTP testing (disables SSL cert validation).
# NODE_ENV=production

# --- Resend (transactional email) --------------------------------------------
# Required — registration, magic links, password resets, and invitations all
# depend on email delivery. Sign up at https://resend.com and create an API key.
RESEND_API_KEY=
# Optional — overrides the default "Flash MDM <noreply@flash-mdm.netlify.app>"
# The domain must be verified in your Resend account.
# RESEND_FROM_EMAIL=

# --- Stripe (licensing & billing) --------------------------------------------
# Optional — only required if you want to enable billing features.
# Dashboard: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=
# Webhook signing secret from Stripe webhook endpoint config
# STRIPE_WEBHOOK_SECRET=

# --- Migrations ---------------------------------------------------------------
# Required to authenticate requests to /api/migrate.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
MIGRATION_SECRET=

# --- Internal function authentication ----------------------------------------
# Shared secret for invoking internal-only functions (background jobs, scheduled
# tasks, deployment processors). Required in all non-local environments.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
INTERNAL_FUNCTION_SECRET=

# --- Licensing enforcement ----------------------------------------------------
# Master kill-switch for enforcement actions (DISABLE/WIPE). Keep false until validated.
LICENSING_ENFORCEMENT_ENABLED=false
# Dry-run mode for reconcile/escalation. Recommended true until rollout is complete.
LICENSING_DRY_RUN=true

# --- Google Cloud (PubSub) ---------------------------------------------------
# Shared secret for authenticating AMAPI PubSub push notifications.
# Choose any strong random string; must match the PubSub subscription config.
# PUBSUB_SHARED_SECRET=

# --- Google Maps (frontend, geofencing) --------------------------------------
# Must have Maps JavaScript API enabled.
# Restrict to your domain in the GCP Console.
# VITE_GOOGLE_MAPS_API_KEY=

# --- Bootstrap (optional) ----------------------------------------------------
# If set, requires this secret as an x-bootstrap-secret header when registering
# the first user. Remove from .env after initial setup.
# BOOTSTRAP_SECRET=

# --- Flash Agent (AI assistant) -----------------------------------------------
# OpenAI API key for the built-in AI assistant. Optional — the assistant feature
# is disabled when this is not set.
# OPENAI_API_KEY=
# Override the default model used by Flash Agent (e.g. gpt-4o, gpt-4o-mini).
# FLASHAGENT_MODEL=
# Maximum tool-call rounds per Flash Agent request (default: 8).
# FLASHAGENT_MAX_TOOL_ROUNDS=8

# --- Data retention (cleanup-scheduled) ---------------------------------------
# These control how long various data types are retained before the nightly
# cleanup job purges them. All values are in days. Defaults shown.
# AUDIT_LOG_RETENTION_DAYS=365
# DEVICE_LOCATION_RETENTION_DAYS=90
# DEVICE_STATUS_REPORT_RETENTION_DAYS=90
# SOFT_DELETED_DEVICE_RETENTION_DAYS=30
# FLASHAGENT_CHAT_RETENTION_DAYS=30
